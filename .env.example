# URL baked into the browser bundle — points to the Next.js app's own origin
# (the /api/monitor proxy handles the actual upstream call server-side)
NEXT_PUBLIC_MONITOR_API_URL=http://localhost:3000

# Server-side connection to monitor-core (never sent to the browser)
MONITOR_API_KEY=your-secret-key

# Keyring (optional — if set, MONITOR_API_URL and MONITOR_API_KEY are fetched
# from Keyring at server startup and override the values above)
# KEYRING_URL=https://keyring.cloud
# KEYRING_ACCESS_KEY_ID=KR...
# KEYRING_SECRET_ACCESS_KEY=...
